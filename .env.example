# Copy this file to .env and fill in real values for your machine/network.
# Never commit .env - it's gitignored.

# Which provider ProviderFactory.fromEnv() builds: "ollama" or "openai"
AI_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b

# Only needed when AI_PROVIDER=openai (or when you want it available as a fallback).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
