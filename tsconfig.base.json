{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@org/ai-core": ["./libs/ai-core/src/index.ts"],
      "@org/providers": ["./libs/providers/src/index.ts"],
      "@org/shared": ["./libs/shared/src/index.ts"],
      "@org/memory": ["./libs/memory/src/index.ts"],
      "@org/chat": ["./libs/chat/src/index.ts"],
      "@org/rag": ["./libs/rag/src/index.ts"],
      "@org/tools": ["./libs/tools/src/index.ts"],
      "@org/agents": ["./libs/agents/src/index.ts"]
    }
  }
}
